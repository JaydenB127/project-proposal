# Database
DATABASE_URL=postgresql+asyncpg://expuser:exppass@localhost:5432/exptracker
SYNC_DATABASE_URL=postgresql+psycopg2://expuser:exppass@localhost:5432/exptracker

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ADMIN_API_KEY=admin-dev-key-change-in-prod

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Cache TTL (seconds)
CACHE_TTL=300

# Run Retention
MAX_RUNS_PER_EXPERIMENT=100
ARCHIVE_AFTER_DAYS=365
